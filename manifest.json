{
  "manifest_version": 3,
  "name": "Google Chat Enter Disable",
  "version": "1.0.0",
  "description": "Google ChatでEnterキーによる送信を無効化し、すべて改行として扱います。送信は送信ボタンのクリックのみ。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
